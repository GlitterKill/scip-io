{
  "permissions": {
    "allow": [
      "Read",
      "Bash",
      "mcp__sdl-mcp__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/force-sdl-mcp.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/force-sdl-runtime.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/force-sdl-explore.sh"
          }
        ]
      }
    ]
  }
}
